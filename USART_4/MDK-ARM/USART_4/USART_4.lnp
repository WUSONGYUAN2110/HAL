"usart_4\stm32f4xx_hal_rcc_ex.o"
"usart_4\stm32f4xx_hal_flash.o"
"usart_4\stm32f4xx_hal_flash_ex.o"
"usart_4\stm32f4xx_hal_flash_ramfunc.o"
"usart_4\stm32f4xx_hal_gpio.o"
"usart_4\stm32f4xx_hal_dma_ex.o"
"usart_4\stm32f4xx_hal_dma.o"
