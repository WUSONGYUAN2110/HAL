--cpu=Cortex-M4.fp.sp
"usart_4\startup_stm32f407xx.o"
"usart_4\main.o"
"usart_4\gpio.o"
"usart_4\usart.o"
"usart_4\stm32f4xx_it.o"
"usart_4\stm32f4xx_hal_msp.o"
"usart_4\stm32f4xx_hal_uart.o"
